# =========================================================================
# SECUREVAULT ENVIRONMENT CONFIGURATION
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND SERVER CONFIGURATION (Save as securevault/server/.env)
# -------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# FIREBASE ADMIN CONFIG (Optional - leaving empty enables self-contained local simulation)
# Paste your Firebase service account JSON credentials as a single line string
# FIREBASE_SERVICE_ACCOUNT_KEY={"type": "service_account", "project_id": "...", ...}
# FIREBASE_STORAGE_BUCKET=your-app-bucket.appspot.com


# -------------------------------------------------------------------------
# FRONTEND CLIENT CONFIGURATION (Save as securevault/client/.env)
# -------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000/api

# FIREBASE CLIENT CREDENTIALS (Optional - leaving empty enables self-contained local simulation)
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-app-bucket.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# VITE_FIREBASE_APP_ID=your-app-id
